{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Flat Style Sheets",
	"scopeName": "source.fss",
	"patterns": [{ "include": "#main" }],
	"repository": {
		"main": {
			"patterns": [
				{ "include": "#comments" },
				{ "include": "#string-double" },
				{ "include": "#string-single" },
				{ "include": "#atDefine" },
				{ "include": "#rule" }
			]
		},
		"comments": {
			"begin": "/\\*",
			"captures": {
				"0": { "name": "punctuation.definition.comment.fss" }
			},
			"end": "\\*/",
			"name": "comment.block.fss"
		},
		"string-double": {
			"name": "string.quoted.double.fss",
			"begin": "\"",
			"end": "\"",
			"patterns": [{ "include": "#string-escape" }]
		},
		"string-single": {
			"name": "string.quoted.single.fss",
			"begin": "'",
			"end": "'",
			"patterns": [{ "include": "#string-escape" }]
		},
		"string-escape": {
			"name": "constant.character.escape.fss",
			"match": "\\\\."
		},
		"atDefine": {
			"begin": "(@define)\\s*(\\{)",
			"beginCaptures": {
				"1": { "name": "keyword.control.define.fss" },
				"2": { "name": "punctuation.definition.block.begin.fss" }
			},
			"end": "\\}",
			"endCaptures": {
				"0": { "name": "punctuation.definition.block.end.fss" }
			},
			"name": "meta.at-rule.define.fss",
			"patterns": [{ "include": "#defineInner" }]
		},
		"defineInner": {
			"patterns": [
				{ "include": "#comments" },
				{
					"match": "(\\$[\\w-]+)\\s*(:)\\s*([^;]+)(;)?",
					"captures": {
						"1": { "name": "variable.other.definition.fss" },
						"2": { "name": "punctuation.separator.key-value.fss" },
						"3": {
							"patterns": [{ "include": "#valueTokens" }]
						},
						"4": { "name": "punctuation.terminator.rule.fss" }
					}
				}
			]
		},
		"rule": {
			"begin": "^\\s*((?:\\.[:\\w-]+|:host(?:\\([^)]*\\))?))\\s*\\{",
			"beginCaptures": {
				"1": { "patterns": [{ "include": "#selectorTokens" }] }
			},
			"end": "\\}",
			"endCaptures": {
				"0": { "name": "punctuation.definition.block.end.fss" }
			},
			"name": "meta.rule.fss",
			"patterns": [{ "include": "#ruleBody" }]
		},
		"selectorTokens": {
			"patterns": [
				{
					"match": ":host\\b",
					"name": "entity.other.attribute-name.pseudo-class.css"
				},
				{
					"match": "\\.[\\w-]+",
					"name": "entity.other.attribute-name.class.css"
				},
				{
					"match": "#[\\w-]+",
					"name": "entity.other.attribute-name.id.css"
				},
				{
					"match": "\\b[a-zA-Z][\\w-]*",
					"name": "invalid.illegal.tag.fss"
				}
			]
		},
		"ruleBody": {
			"patterns": [
				{ "include": "#comments" },
				{ "include": "#string-double" },
				{ "include": "#string-single" },
				{
					"begin": "([\\w-]+)\\s*(:)",
					"beginCaptures": {
						"1": { "name": "support.type.property-name.css" },
						"2": { "name": "punctuation.separator.key-value.css" }
					},
					"end": ";|(?=\\})",
					"endCaptures": {
						"0": { "name": "punctuation.terminator.rule.css" }
					},
					"name": "meta.property-list.css",
					"patterns": [{ "include": "#valueTokens" }]
				}
			]
		},
		"valueTokens": {
			"patterns": [
				{ "include": "#comments" },
				{ "include": "#string-double" },
				{ "include": "#string-single" },
				{
					"match": "\\$[\\w-]+\\b",
					"name": "variable.other.fss"
				},
				{
					"match": "#[0-9a-fA-F]{3,8}\\b",
					"name": "constant.other.color.rgb-value.css"
				},
				{
					"match": "\\b\\d+(\\.\\d+)?(px|rem|em|%|vh|vw|vmin|vmax|deg|ms|s|fr|ch|ex|cm|mm|in|pt|pc)\\b",
					"name": "constant.numeric.css"
				},
				{
					"match": "\\b\\d+(\\.\\d+)?\\b",
					"name": "constant.numeric.css"
				}
			]
		}
	}
}
