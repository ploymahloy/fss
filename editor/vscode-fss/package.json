{
	"name": "vscode-fss",
	"displayName": "Flat Style Sheets (FSS)",
	"description": "Syntax highlighting, diagnostics, completions, and hover for Flat Style Sheets (.fss).",
	"version": "1.0.0",
	"publisher": "fss",
	"license": "ISC",
	"type": "module",
	"keywords": ["fss", "css", "stylesheet", "flat-style-sheets", "language"],
	"homepage": "https://github.com/ploymahloy/fss/tree/main/editor",
	"bugs": {
		"url": "https://github.com/ploymahloy/fss/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ploymahloy/fss.git",
		"directory": "editor/vscode-fss"
	},
	"engines": {
		"vscode": "^1.96.0"
	},
	"categories": ["Programming Languages"],
	"galleryBanner": {
		"color": "#1e1e1e",
		"theme": "dark"
	},
	"activationEvents": ["onLanguage:fss"],
	"main": "./out/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "fss",
				"aliases": ["Flat Style Sheets", "FSS"],
				"extensions": [".fss"],
				"configuration": "./syntaxes/language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "fss",
				"scopeName": "source.fss",
				"path": "./syntaxes/fss.tmLanguage.json"
			}
		],
		"iconThemes": [
			{
				"id": "fss-files",
				"label": "FSS File Icons",
				"path": "./themes/fss-icon-theme.json"
			}
		]
	},
	"scripts": {
		"compile": "npm run sync-assets && npm run copy-server && tsc -p ./",
		"sync-assets": "mkdir -p syntaxes && cp ../grammars/fss.tmLanguage.json syntaxes/ && cp ../grammars/language-configuration.json syntaxes/",
		"copy-server": "mkdir -p server/out && cp ../fss-language-server/out/server.js server/out/",
		"watch": "tsc -watch -p ./",
		"vscode:prepublish": "npm run compile",
		"build": "npm run compile",
		"vsix": "vsce package"
	},
	"dependencies": {
		"vscode-languageclient": "^9.0.1"
	},
	"devDependencies": {
		"@vscode/vsce": "^3.7.1",
		"@types/vscode": "^1.96.0",
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3"
	}
}
