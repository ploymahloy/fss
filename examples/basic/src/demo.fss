:host {
	display: block;
	padding: 1.25rem;
	font-family: system-ui, sans-serif;
	background: #0f172a;
	color: #e2e8f0;
	border-radius: 8px;
	max-width: 28rem;
}

.title {
	font-size: 1.125rem;
	font-weight: 600;
	color: #5eead4;
	margin: 0 0 0.5rem;
}

.hint {
	font-size: 0.875rem;
	color: #94a3b8;
	margin: 0;
}
